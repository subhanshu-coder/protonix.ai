# Google OAuth Configuration
# Important: Get your own Google OAuth Client ID from Google Cloud Console
# The client ID must have http://localhost:5173 and http://localhost:5000 in Authorized JavaScript origins
# and be configured to allow implicit flow
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Backend Configuration
VITE_API_URL=http://localhost:5000

# Database
MONGODB_URI=mongodb://localhost:27017/protonix

# JWT Secret
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email Configuration (for password reset)
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# API Keys for Models (from OpenRouter)
PERPLEXITY_OR_KEY=your_perplexity_key
GEMINI_OR_KEY=your_gemini_key
CLAUDE_OR_KEY=your_claude_key
GROQ_API_KEY=your_groq_key
GPT_OR_KEY=your_gpt_key
DEEPSEEK_OR_KEY=your_deepseek_key

# Google Client ID (backend verification)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Server Port
PORT=5000
